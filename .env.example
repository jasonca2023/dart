# Copy to .env and fill in. NEVER commit the real .env.
# All keys below are SERVER-SIDE ONLY — they must never reach the browser/frontend.

# --- LLM (script generation) ---
ANTHROPIC_API_KEY=
# Model id is configurable; do not hard-code in source.
# One of: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
SCRIPT_MODEL=claude-opus-4-8

# --- Video generation provider: "ltx" | "kling" | "mock" ---
VIDEO_PROVIDER=ltx
# LTX Video (Lightricks) — get a key at https://app.ltx.video
LTX_API_KEY=
LTX_MODEL=ltx-2-fast
LTX_GENERATE_AUDIO=true
# Alternative provider (Kling) — confirm endpoints before use:
# VIDEO_PROVIDER=kling
# KLING_SECRET_KEY=

# --- Scraper: "jsonld" (real web scraper) | "mock" ---
SCRAPER_PROVIDER=jsonld
# Optional local MCP scraping server:
MCP_SCRAPER_URL=http://localhost:5001

# --- Datastore (Supabase / Postgres) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Backend service ---
BACKEND_PORT=8000

# --- Frontend (only NEXT_PUBLIC_* values are exposed to the browser) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
