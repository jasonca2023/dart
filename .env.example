# Copy to .env and fill in. NEVER commit the real .env.
# These are the BACKEND's settings (server-side only — none may reach the
# browser). The frontend's public config lives in frontend/.env.local, below.

# ============================================================================
# The shipped app (browser-rendered ads saved to Supabase)
# ============================================================================

# --- Supabase (auth + the saved-ads library) ---
# Project URL, e.g. https://<ref>.supabase.co. Required for POST /save-ad;
# setting it also makes the write endpoints require a valid login.
SUPABASE_URL=
# Service-role key (sb_secret_…). Used by /save-ad to upload the rendered video
# and write the library row (Storage rejects user JWTs directly). KEEP SECRET.
SUPABASE_SERVICE_KEY=

# --- CORS ---
# JSON array of allowed frontend origins. Defaults to ["http://localhost:3000"]
# for local dev; in production set it to your deployed frontend, e.g.
# CORS_ORIGINS=["https://dart-frontend.YOURNAME.workers.dev"]

# --- Service ---
BACKEND_PORT=8000

# --- Rate limiting (per client IP; optional — sane defaults built in) ---
# Blunts abuse of the open proxy/scrape endpoints and the save path. Tune only
# if you need to; set RATE_LIMIT_ENABLED=false for local dev with no proxy.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PROXY_PER_MIN=120
# RATE_LIMIT_STORE_PER_MIN=30
# RATE_LIMIT_SAVE_PER_MIN=60
# RATE_LIMIT_JOBS_PER_MIN=30

# ----------------------------------------------------------------------------
# Frontend config lives in frontend/.env.local (NOT this file — Next.js doesn't
# read the repo root). Only NEXT_PUBLIC_* values reach the browser, and the
# Supabase publishable/anon key is browser-safe by design:
#
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_…
#
# Ad copy runs on Cloudflare Workers AI via the AI binding in
# frontend/wrangler.jsonc — no key (local dev falls back to rule-based copy).
# ----------------------------------------------------------------------------

# ============================================================================
# LEGACY server-side video pipeline (/jobs). Retained in the codebase but NOT
# used by the shipped app — leave everything below unset unless reviving it.
# ============================================================================

# Video generation: "client" (browser renders — the shipped flow) | "ltx" |
# "kling" | "mock" (default).
# VIDEO_PROVIDER=mock
# LTX Video (Lightricks) — get a key at https://app.ltx.video
# LTX_API_KEY=
# LTX_MODEL=ltx-2-fast
# LTX_GENERATE_AUDIO=true
# Alternative provider (Kling) — confirm endpoints before use:
# KLING_SECRET_KEY=

# Scraper: "jsonld" (real web scraper) | "mock" (default)
# SCRAPER_PROVIDER=mock
# Optional local MCP scraping server:
# MCP_SCRAPER_URL=http://localhost:5001

# LLM script generation (Anthropic). Model id is configurable; do not hard-code
# in source. One of: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=
# SCRIPT_MODEL=claude-opus-4-8
